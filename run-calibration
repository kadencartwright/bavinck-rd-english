#!/usr/bin/env sh
set -eu

manifest="config/calibration/run-manifests/vol2-god-incomprehensibility-001-baseline.json"
prev=""
has_manifest=0
for arg in "$@"; do
  if [ "$prev" = "--run-manifest" ]; then
    manifest="$arg"
    has_manifest=1
    break
  fi
  case "$arg" in
    --run-manifest=*)
      manifest="${arg#*=}"
      has_manifest=1
      break
      ;;
  esac
  prev="$arg"
done

echo "[run-calibration] validating manifest: $manifest" >&2
if [ "$#" -eq 0 ]; then
  echo "[run-calibration] starting NestJS runner with default manifest" >&2
  exec pnpm run calibration -- --run-manifest "$manifest"
fi

if [ "$has_manifest" -eq 1 ]; then
  echo "[run-calibration] starting NestJS runner with explicit manifest arguments" >&2
  exec pnpm run calibration -- "$@"
fi

echo "[run-calibration] starting NestJS runner with default manifest and extra flags" >&2
exec pnpm run calibration -- --run-manifest "$manifest" "$@"
