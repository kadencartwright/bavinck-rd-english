{
  "schema_version": "1.0",
  "model_profile_id": "kimi-k2_5-glm5-baseline",
  "description": "Baseline calibration pairing from the project plan: Kimi K2.5 for translation and GLM-5 for review tasks.",
  "stages": {
    "translation": {
      "provider": "moonshot",
      "model": "kimi-k2.5",
      "mode": "batch",
      "temperature": 0.2,
      "max_tokens": 6000,
      "timeout_seconds": 300,
      "notes": "Primary draft translation for theological prose."
    },
    "review": {
      "provider": "z-ai",
      "model": "glm-5",
      "mode": "batch",
      "temperature": 0.1,
      "max_tokens": 3000,
      "timeout_seconds": 300,
      "notes": "Structured review and consistency checks."
    }
  }
}
