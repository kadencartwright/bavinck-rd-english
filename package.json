{
  "name": "bavinck-rd-english",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "baml:generate": "baml-cli generate --from baml_src",
    "baml:test": "baml-cli test --from baml_src",
    "build": "pnpm baml:generate && nest build calibration-cli",
    "calibration": "nest start calibration-cli -- run",
    "glossary:candidates:mine": "nest start calibration-cli -- mine-glossary-candidates",
    "lint": "pnpm baml:generate && tsc --noEmit -p tsconfig.json",
    "nest": "nest",
    "test": "pnpm baml:generate && pnpm baml:test && jest --runInBand",
    "test:watch": "pnpm baml:generate && jest --watch",
    "typecheck": "pnpm baml:generate && tsc --noEmit -p tsconfig.json",
    "worktree:setup": "./scripts/worktree-setup.sh"
  },
  "dependencies": {
    "@boundaryml/baml": "^0.221.0",
    "@langchain/langgraph": "^1.2.8",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.5.2",
    "eslint": "^9.35.0",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
