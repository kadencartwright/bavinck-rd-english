#!/usr/bin/env sh
set -eu

manifest_list="config/calibration/run-manifests/vol2-parallel-10.txt"
max_parallel=2
retry_failed=0
run_calibration_bin="${RUN_CALIBRATION_BIN:-./run-calibration}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --manifest-list)
      manifest_list="$2"
      shift 2
      ;;
    --manifest-list=*)
      manifest_list="${1#*=}"
      shift
      ;;
    --max-parallel)
      max_parallel="$2"
      shift 2
      ;;
    --max-parallel=*)
      max_parallel="${1#*=}"
      shift
      ;;
    --retry-failed)
      retry_failed=1
      shift
      ;;
    *)
      echo "usage: ./run-calibration-batch [--manifest-list PATH] [--max-parallel N] [--retry-failed]" >&2
      exit 2
      ;;
  esac
done

if [ ! -f "$manifest_list" ]; then
  echo "[run-calibration-batch] manifest list not found: $manifest_list" >&2
  exit 1
fi

case "$max_parallel" in
  ''|*[!0-9]*)
    echo "[run-calibration-batch] --max-parallel must be a positive integer" >&2
    exit 2
    ;;
  0)
    echo "[run-calibration-batch] --max-parallel must be greater than zero" >&2
    exit 2
    ;;
esac

log_root="data/calibration/runs/logs"
mkdir -p "$log_root"

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT INT TERM

run_one() {
  manifest_path="$1"
  run_name=$(basename "$manifest_path" .json)
  log_path="$log_root/$run_name.log"
  status_log_path="$log_root/$run_name.status"
  echo "[run-calibration-batch] starting $run_name" >&2
  if "$run_calibration_bin" --run-manifest "$manifest_path" >"$log_path" 2>&1; then
    echo "ok" >"$status_log_path"
    return 0
  fi
  classify_failure "$log_path" >"$status_log_path"
  return 1
}

classify_failure() {
  log_path="$1"
  if rg -q "engine_overloaded|finish_reason 'engine_overloaded'|response ended with finish_reason 'engine_overloaded'" "$log_path"; then
    echo "engine-overloaded"
    return
  fi
  echo "fail"
}

should_retry_failed_run() {
  manifest_path="$1"
  run_name=$(basename "$manifest_path" .json)
  status_log_path="$log_root/$run_name.status"
  translation_response_path="data/calibration/runs/$run_name/outputs/translation-response-round-0.json"
  legacy_translation_response_path="data/calibration/runs/$run_name/outputs/translation-response.json"

  if [ -f "$status_log_path" ] && [ "$(cat "$status_log_path")" = "engine-overloaded" ]; then
    return 0
  fi

  response_probe_path=""
  if [ -f "$translation_response_path" ]; then
    response_probe_path="$translation_response_path"
  elif [ -f "$legacy_translation_response_path" ]; then
    response_probe_path="$legacy_translation_response_path"
  fi

  if [ -n "$response_probe_path" ]; then
    if node -e '
const fs = require("node:fs");
const path = process.argv[1];
try {
  const payload = JSON.parse(fs.readFileSync(path, "utf8"));
  const choices = payload.choices;
  if (Array.isArray(choices) && choices.length > 0) {
    const firstChoice = choices[0];
    if (firstChoice && typeof firstChoice === "object" && firstChoice.finish_reason === "engine_overloaded") {
      process.exit(0);
    }
  }
} catch {}
process.exit(1);
' "$response_probe_path"
    then
      return 0
    fi
  fi

  return 1
}

index=0
active=0
while IFS= read -r manifest_path || [ -n "$manifest_path" ]; do
  if [ -z "$manifest_path" ]; then
    continue
  fi
  if [ "$retry_failed" -eq 1 ]; then
    run_name=$(basename "$manifest_path" .json)
    if ! should_retry_failed_run "$manifest_path"; then
      echo "[run-calibration-batch] skipping $run_name (no prior engine_overloaded failure found)" >&2
      continue
    fi
    echo "[run-calibration-batch] retrying engine_overloaded run $run_name" >&2
  fi
  index=$((index + 1))
  status_path="$tmpdir/$index.status"
  (
    if run_one "$manifest_path"; then
      echo "ok $manifest_path" >"$status_path"
    else
      echo "fail $manifest_path" >"$status_path"
    fi
  ) &
  active=$((active + 1))
  if [ "$active" -ge "$max_parallel" ]; then
    wait
    active=0
  fi
done <"$manifest_list"

if [ "$index" -eq 0 ]; then
  if [ "$retry_failed" -eq 1 ]; then
    echo "[run-calibration-batch] no engine_overloaded runs matched the manifest list" >&2
  else
    echo "[run-calibration-batch] no manifests matched the manifest list" >&2
  fi
  exit 0
fi

wait

failures=0
for status_file in "$tmpdir"/*.status; do
  [ -e "$status_file" ] || continue
  status=$(cut -d' ' -f1 <"$status_file")
  manifest_path=$(cut -d' ' -f2- <"$status_file")
  run_name=$(basename "$manifest_path" .json)
  if [ "$status" = "ok" ]; then
    echo "[run-calibration-batch] completed $run_name" >&2
  else
    echo "[run-calibration-batch] failed $run_name (see $log_root/$run_name.log)" >&2
    failures=$((failures + 1))
  fi
done

if [ "$failures" -gt 0 ]; then
  echo "[run-calibration-batch] finished with $failures failure(s)" >&2
  exit 1
fi

echo "[run-calibration-batch] all runs completed successfully" >&2
