#!/usr/bin/env sh
set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
cd "$repo_root"

gitleaks_bin=${GITLEAKS_BIN:-gitleaks}

if ! command -v "$gitleaks_bin" >/dev/null 2>&1; then
  echo "[secret-scan] gitleaks is required for pre-commit scanning but was not found on PATH." >&2
  echo "[secret-scan] Install gitleaks or set GITLEAKS_BIN to the scanner binary path." >&2
  exit 1
fi

echo "[secret-scan] scanning staged changes for secrets with $gitleaks_bin" >&2

exec "$gitleaks_bin" git \
  --staged \
  --pre-commit \
  --redact=20 \
  --no-banner \
  --no-color
